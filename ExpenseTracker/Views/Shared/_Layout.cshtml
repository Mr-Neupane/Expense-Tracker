<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>@ViewData["Title"] - ExpenseTracker</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico"/>
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
  <link rel="stylesheet" href="~/ExpenseTracker.styles.css" asp-append-version="true"/>
  @await Html.PartialAsync("_CssPartial")
</head>

<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
  <header>
    <div class="app-wrapper">
      <nav class="app-header navbar navbar-expand bg-body">
        <div class="container-fluid">
          <ul class="navbar-nav">
            <li class="nav-item">
              <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                <i class="bi bi-list"></i>
              </a>
            </li>
            <li class="nav-item d-none d-md-block">
              <a asp-action="Index" asp-controller="Home" class="nav-link">Home</a>
            </li>
            <li class="nav-item dropdown d-none d-md-block">
              <a class="nav-link dropdown-toggle" href="#" id="contactDropdown" role="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                Basic Setup
              </a>
              <ul class="dropdown-menu" aria-labelledby="contactDropdown">
                <li class="dropdown-submenu">
                  <a class="dropdown-item dropdown-toggle" href="#">Ledger</a>
                  <ul class="dropdown-menu">
                    <li><a class="dropdown-item" asp-controller="Ledger" asp-action="CreateParentLedger">Add Parent Ledger</a></li>
                    <li><a class="dropdown-item" asp-controller="Ledger" asp-action="CreateLedger">Add Ledger</a></li>
                  </ul>
                </li>
                <li class="dropdown-submenu">
                  <a class="dropdown-item dropdown-toggle" href="#">Bank</a>
                  <ul class="dropdown-menu">
                    <li><a class="dropdown-item" asp-controller="Bank" asp-action="CreateBank">Create Bank</a></li>
                  </ul>
                </li>
                <li class="dropdown-submenu">
                  <a class="dropdown-item dropdown-toggle" href="#">Basic Reports</a>
                  <ul class="dropdown-menu">
                    <li><a class="dropdown-item" asp-controller="Ledger" asp-action="ParentLedgerReport">Parent Ledger Report</a></li>
                    <li><a class="dropdown-item" asp-controller="Ledger" asp-action="LedgerReport">Ledger List</a></li>
                    <li><a class="dropdown-item" asp-controller="Bank" asp-action="BankReport">Bank Report</a></li>
                  </ul>
                </li>
              </ul>
            </li>
            <li class="nav-item dropdown d-none d-md-block">
              <a class="nav-link dropdown-toggle" href="#" id="transactionDropdown" role="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                Transactions
              </a>
              <ul class="dropdown-menu" aria-labelledby="transactionDropdown">
                <li><a class="dropdown-item" asp-controller="BankTransaction" asp-action="BankDepositandWithdraw">Record Bank Transaction</a></li>
                <li><a class="dropdown-item" asp-controller="Expense" asp-action="RecordExpense">Record Expense</a></li>
                <li><a class="dropdown-item" asp-controller="Income" asp-action="RecordIncome">Record Income</a></li>
                <li><a class="dropdown-item" asp-controller="Liability" asp-action="AddLiability">Record Liability</a></li>
                <li><a class="dropdown-item" asp-controller="Voucher" asp-action="AddJv">Record Journal Voucher</a></li>
              </ul>
            </li>
            <li class="nav-item dropdown d-none d-md-block">
              <a class="nav-link dropdown-toggle" href="#" id="reportsDropdown" role="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                Reporting
              </a>
              <ul class="dropdown-menu" aria-labelledby="reportsDropdown">
                <li class="dropdown-submenu">
                  <a class="dropdown-item dropdown-toggle" href="#">Basic Reports</a>
                  <ul class="dropdown-menu">
                    <li><a class="dropdown-item" asp-controller="Expense" asp-action="ExpenseReport">Expense Report</a></li>
                    <li><a class="dropdown-item" asp-controller="Income" asp-action="IncomeReport">Income Report</a></li>
                    <li><a class="dropdown-item" asp-controller="Liability" asp-action="LiabilityReport">Liability Report</a></li>
                  </ul>
                </li>
                <li class="dropdown-submenu">
                  <a class="dropdown-item dropdown-toggle" href="#">Advance Reports</a>
                  <ul class="dropdown-menu">
                    <li><a class="dropdown-item" asp-controller="Voucher" asp-action="AccountingTransaction">Accounting Transaction</a></li>
                    <li><a class="dropdown-item" asp-controller="Ledger" asp-action="LedgerStatement">Ledger Statement</a></li>
                  </ul>
                </li>
              </ul>
            </li>
          </ul>
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <a class="nav-link" href="#" data-lte-toggle="fullscreen">
                <i data-lte-icon="maximize" class="bi bi-arrows-fullscreen"></i>
                <i data-lte-icon="minimize" class="bi bi-fullscreen-exit" style="display: none"></i>
              </a>
            </li>
            @if (User.Identity?.IsAuthenticated == true)
            {
              <li class="nav-item dropdown user-menu">
                <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                  <img class="user-image rounded-circle shadow" alt="User Image"/>
                  <span class="d-none d-md-inline">@User.Identity.Name</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-end">
                  <li class="user-header text-bg-primary">
                    <img class="rounded-circle shadow" alt="User Image"/>
                    <p>@User.Identity.Name</p>
                  </li>
                  <li class="user-body"></li>
                  <li class="user-footer">
                    <a href="#" class="btn btn-outline-secondary">Profile</a>
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger float-end">Sign out</a>
                  </li>
                </ul>
              </li>
            }
            else
            {
              <li class="nav-item">
                <a class="nav-link" asp-controller="Account" asp-action="Login">
                  <i class="bi bi-box-arrow-in-right"></i> Sign in
                </a>
              </li>
            }
          </ul>
        </div>
      </nav>
      @await Html.PartialAsync("_SidebarPartial")
      <main role="main" class="app-main pb-3">
        @RenderBody()
        <div class="app-content-header">
          <div class="container-fluid">
            <div class="row"></div>
          </div>
        </div>
      </main>
    </div>
  </header>

  @await Html.PartialAsync("_JsPartial")

  @await RenderSectionAsync("Scripts", required: false)
  @await Component.InvokeAsync("NToastNotify")

</body>
